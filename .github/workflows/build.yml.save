name: Build APK
on: [push]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Build with Buildozer
        uses: docker://buildozer/buildozer:latest
      with: command: buildozer android debug - name: 
      Upload APK
        args: buildozer android debug        uses: actions/upload-artifact@v4
        with:
          name: package
          path: bin/*.apk
