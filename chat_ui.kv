<ChatBubble@BoxLayout>:
    orientation: 'vertical'
    padding: 10
    size_hint_y: None
    height: self.minimum_height
    canvas.before:
        Color:
            rgba: (0.2, 0.2, 0.2, 1) if self.is_bot else (0.1, 0.4, 0.8, 1)
        RoundedRectangle:
            size: self.size
            pos: self.pos
            radius: [15, 15, 15, 15]

    Label:
        text: root.text
        text_size: self.width, None
        size_hint_y: None
        height: self.texture_size[1]
