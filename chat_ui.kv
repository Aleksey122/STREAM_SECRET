BoxLayout:
    orientation: 'vertical'
    padding: 10
    spacing: 10
    canvas.before:
        Color:
            rgba: 0.1, 0.1, 0.1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: 'MAX AI'
        size_hint_y: None
        height: 40
        color: 0, 1, 0, 1

    ScrollView:
        BoxLayout:
            id: chat_container
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: 10
            spacing: 10

    TextInput:
        id: message_input
        size_hint_y: None
        height: 50
        multiline: False
        hint_text: 'Введите сообщение...'
