[app]
title = MAX AI
package.name = maxai
source.dir = .
package.domain = org.maxai
source.include_exts = py,png,jpg,kv,atlas
version = 0.1
requirements = python3,kivy,requests,plyer
android.permissions = INTERNET,CAMERA,WRITE_EXTERNAL_STORAGE,READ_EXTERNAL_STORAGE,RECORD_AUDIO

[buildozer]
log_level = 2
warn_on_root = 1
