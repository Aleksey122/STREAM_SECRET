[app]
title = TrollBox
package.name = trollbox
package.domain = org.test
source.include_exts = py,png,jpg,kv,atlas
version = 1.0.1
requirements = python3,kivy,plyer,kivymd
android.permissions = RECORD_AUDIO,WRITE_EXTERNAL_STORAGE,READ_EXTERNAL_STORAGE
android.api = 33
android.minapi = 21

[buildozer]
log_level = 2
warn_on_root = 1
